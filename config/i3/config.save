qset $mod Mod4

# --- apps ---
set $term xterm 
set $lightTerm xterm
set $fileMgr pcmanfm
set $menu rofi -show drun -theme ~/.config/rofi/themes/my-theme.rasi -show-icons

# --- autostart ---
exec --no-startup-id picom
exec --no-startup-id ~/bin/set-wallpaper.sh
exec --no-startup-id dunst
exec --no-startup-id nm-applet
exec --no-startup-id xss-lock -- ~/bin/lock.sh
exec --no-startup-id xidlehook --not-when-fullscreen --timer 600 'systemctl suspend' '' 

# --- looks ---
font pango:sans 10

gaps inner 1
gaps outer 0

default_border pixel 1
default_floating_border pixel 1

client.focused          #357ec7 #357ec7 #eeeeee #357ec7
client.unfocused        #222222 #222222 #eeeeee #222222
client.focused_inactive #333333 #333333 #eeeeee #333333
client.urgent           #cc241d #cc241d #eeeeee #cc241d

hide_edge_borders none

# --- mouse ---
floating_modifier $mod
tiling_drag modifier titlebar

focus_follows_mouse yes

mouse_warping none

# --- bar ---
bar {
    status_command i3status -c ~/.config/i3status/config
    colors {
        background #111111
        statusline #eeeeee
        separator  #dddddd

        focused_workspace  #357ec7 #357ec7 #eeeeee
        active_workspace   #222222 #222222 #eeeeee
        inactive_workspace #333333 #333333 #eeeeee
        urgent_workspace   #cc241d #cc241d #eeeeee
    }
    tray_output primary
}

# --- shorcuts ---
bindsym $mod+q exec --no-startup-id $term
bindsym $mod+Shift+q exec --no-startup-id $lightTerm
bindsym $mod+e exec --no-startup-id $fileMgr
bindsym $mod+d exec --no-startup-id $menu

bindsym $mod+c kill
bindsym $mod+v floating toggle
bindsym $mod+f fullscreen toggle

bindsym $mod+Ctrl+l exec --no-startup-id ~/bin/lock.sh
bindsym $mod+Shift+r reload
bindsym $mod+Escape exec --no-startup-id ~/bin/power-menu.sh
bindsym $mod+m exec i3-msg exit

bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bindsym $mod+o split h
bindsym $mod+p split v

bindsym $mod+w layout tabbed
bindsym $mod+s layout stacking
bindsym $mod+e layout default

bindsym $mod+1 workspace "1"
bindsym $mod+2 workspace "2"
bindsym $mod+3 workspace "3"
bindsym $mod+4 workspace "4"
bindsym $mod+5 workspace "5"
bindsym $mod+6 workspace "6"
bindsym $mod+7 workspace "7"
bindsym $mod+8 workspace "8"
bindsym $mod+9 workspace "9"
bindsym $mod+0 workspace "10"

bindsym $mod+Shift+1 move container to workspace "1"
bindsym $mod+Shift+2 move container to workspace "2"
bindsym $mod+Shift+3 move container to workspace "3"
bindsym $mod+Shift+4 move container to workspace "4"
bindsym $mod+Shift+5 move container to workspace "5"
bindsym $mod+Shift+6 move container to workspace "6"
bindsym $mod+Shift+7 move container to workspace "7"
bindsym $mod+Shift+8 move container to workspace "8"
bindsym $mod+Shift+9 move container to workspace "9"
bindsym $mod+Shift+0 move container to workspace "10"

bindsym Print       exec --no-startup-id flameshot gui --clipboard --path ~/Pictures/Screenshots
bindsym Shift+Print exec --no-startup-id flameshot gui
bindsym Ctrl+Print  exec --no-startup-id flameshot full --clipboard --path ~/Pictures/Screenshots
    
# TODO: media keys

# --- window rules ---
for_window [window_type="dialog"] floating enable
