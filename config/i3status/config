general {
    colors = true
    interval = 2
}

order += "wireless _first_"
order += "ethernet _first_"
order += "cpu_usage"
order += "memory"
order += "tztime local"

wireless _first_ {
    format_up  = "WiFi: %essid (%ip)"
    format_down = "WiFi: down"
}

ethernet _first_ {
    format_up   = "ETH: %ip"
    format_down = "ETH: down"
}

cpu_usage {
    format = "CPU: %usage"
}

memory {
    format = "RAM: %used"
}

tztime local {
    format = "%d-%m-%Y %H:%M "
}
