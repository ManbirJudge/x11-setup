[global]
origin = top-right
offset = (4, 4)

width = 350

font=sans 11
transparency = 0
corner_radius = 6
frame_width = 1

icon_position = left
enable_recursive_icon_lookup = true

show_indicators = true

timeout = 7
stack_duplicates = true
history_length = 50

progress_bar = true
progress_bar_height = 10

mouse_left_click = do_action
mouse_middle_click = close_current

[urgency_low]
background = "#222222"
foreground = "#eeeeee"
frame_color = "#eeeeee"

[urgency_normal]
background = "#222222"
foreground = "#eeeeee"
frame_color = "#537ec7"

[urgency_critical]
background = "#222222"
foreground = "#cc241d"
frame_color = "#cc241d"
